+            {"printerIntName", "F018"},
+            {"nozzleDiameter", json::array({"0.4"})},
+            {"name", "Creality Hi"},
+            {"type", 1},
+            {"xSize", 260},
+            {"ySize", 260},
+            {"zSize", 300},
+            {"seriesId", 77814183},
+            {"supMaterialType", json::array({"PLA", "ABS", "TPU", "PETG", "PLA-CF"})}
+        }
+    });
+}
