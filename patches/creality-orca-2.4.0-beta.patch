+bool Sidebar::can_sync_creality_cfs() const
+{
+    PresetBundle* preset_bundle = wxGetApp().preset_bundle;
+    if (!preset_bundle)
+        return false;
+
+    const DynamicPrintConfig& cfg = preset_bundle->printers.get_edited_preset().config;
+    const auto* host_type_opt = cfg.option<ConfigOptionEnum<PrintHostType>>("host_type");
+    return host_type_opt && host_type_opt->value == htCrealityPrint &&
+           cfg.has("print_host") && !cfg.opt_string("print_host").empty() &&
+           (!cfg.has("single_extruder_multi_material") || cfg.opt_bool("single_extruder_multi_material"));
+}
+
+bool Sidebar::load_creality_cfs_list()
+{
+    PresetBundle* preset_bundle = wxGetApp().preset_bundle;
+    if (!preset_bundle)
+        return false;
+
+    DynamicPrintConfig cfg = preset_bundle->printers.get_edited_preset().config;
+    CrealityPrint creality_host(&cfg);
+    auto cfs_slots = creality_host.query_cfs_slots(false);
+
+    std::map<int, DynamicPrintConfig> filament_ams_list;
+    int tray_idx = 0;
+    for (const auto& slot : cfs_slots) {
+        if (slot.external || slot.type.empty())
+            continue;
+
+        std::string filament_id = preset_bundle->filaments.filament_id_by_type(slot.type);
+        wxColour colour(slot.color);
+        if (!colour.IsOk())
+            colour = wxColour("#FFFFFF");
+
+        DynamicPrintConfig tray_config;
+        tray_config.set_key_value("filament_id", new ConfigOptionStrings{filament_id});
+        tray_config.set_key_value("tag_uid", new ConfigOptionStrings{});
+        tray_config.set_key_value("ams_id", new ConfigOptionStrings{std::to_string(slot.box_id)});
+        tray_config.set_key_value("slot_id", new ConfigOptionStrings{std::to_string(slot.material_id)});
+        tray_config.set_key_value("filament_type", new ConfigOptionStrings{slot.type});
+        tray_config.set_key_value("tray_name", new ConfigOptionStrings{slot.tool_id.size() > 1 ? slot.tool_id.substr(1) : slot.tool_id});
+        tray_config.set_key_value("filament_colour", new ConfigOptionStrings{into_u8(colour.GetAsString(wxC2S_HTML_SYNTAX))});
+        tray_config.set_key_value("filament_multi_colour", new ConfigOptionStrings{});
+        tray_config.set_key_value("filament_colour_type", new ConfigOptionStrings{"0"});
+        tray_config.set_key_value("filament_exist", new ConfigOptionBools{true});
+        tray_config.set_key_value("filament_slot_placeholder", new ConfigOptionBools{false});
+
+        std::optional<FilamentBaseInfo> info = preset_bundle->get_filament_by_filament_id(filament_id);
+        tray_config.set_key_value("filament_is_support", new ConfigOptionBools{info.has_value() ? info->is_support : false});
+
+        filament_ams_list.emplace(tray_idx++, std::move(tray_config));
+    }
+
+    p->ams_list_device = "crealityprint:" + cfg.opt_string("print_host");
+    wxGetApp().preset_bundle->filament_ams_list = filament_ams_list;
+    for (auto c : p->combos_filament)
+        c->update();
+    p->combo_printer->update();
+
+    return !filament_ams_list.empty();
+}
+
+void Sidebar::show_creality_cfs_slots()
+{
+    PresetBundle* preset_bundle = wxGetApp().preset_bundle;
+    if (!preset_bundle || !can_sync_creality_cfs()) {
+        MessageDialog dlg(this,
+            _L("Select a Creality Print host before reading CFS slots."),
+            _L("CFS Slots"), wxOK);
+        dlg.ShowModal();
+        return;
+    }
+
+    DynamicPrintConfig cfg = preset_bundle->printers.get_edited_preset().config;
+    CrealityPrint creality_host(&cfg);
+
+    std::vector<CrealityPrint::CfsSlotInfo> slots;
+    {
+        wxBusyCursor wait;
+        slots = creality_host.query_cfs_slots(true);
+    }
+
+    wxDialog dlg(this, wxID_ANY, _L("CFS Slots"), wxDefaultPosition, wxDefaultSize,
+                 wxDEFAULT_DIALOG_STYLE | wxRESIZE_BORDER);
+    auto* main_sizer = new wxBoxSizer(wxVERTICAL);
+    main_sizer->Add(new wxStaticText(&dlg, wxID_ANY, _L("CFS Slots")), 0, wxALL, FromDIP(12));
+
+    if (slots.empty()) {
+        auto* empty = new wxStaticText(&dlg, wxID_ANY, _L("No CFS or external spool data was returned by the printer."));
+        empty->Wrap(FromDIP(420));
+        main_sizer->Add(empty, 0, wxLEFT | wxRIGHT | wxBOTTOM, FromDIP(12));
+    } else {
+        auto* grid = new wxFlexGridSizer(0, 5, FromDIP(8), FromDIP(12));
+        auto add_header = [grid, &dlg](const wxString& text) {
+            auto* label = new wxStaticText(&dlg, wxID_ANY, text);
+            label->SetFont(::Label::Head_13);
+            grid->Add(label, 0, wxALIGN_CENTER_VERTICAL);
+        };
+        add_header(_L("Slot"));
+        add_header(_L("Source"));
+        add_header(_L("Type"));
+        add_header(_L("Color"));
+        add_header(_L("Status"));
+
+        for (const auto& slot : slots) {
+            wxString slot_name = slot.external ? _L("External") :
+                from_u8(slot.tool_id.size() > 1 ? slot.tool_id.substr(1) : slot.tool_id);
+            wxString source = slot.external ? _L("Spool") :
+                wxString::Format("CFS %d", slot.box_id);
+            wxString type = slot.type.empty() ? _L("Unknown") : from_u8(slot.type);
+            wxString status = slot.external ? (slot.loaded ? _L("Detected") : _L("No material data")) : _L("Loaded");
+
+            grid->Add(new wxStaticText(&dlg, wxID_ANY, slot_name), 0, wxALIGN_CENTER_VERTICAL);
+            grid->Add(new wxStaticText(&dlg, wxID_ANY, source), 0, wxALIGN_CENTER_VERTICAL);
+            grid->Add(new wxStaticText(&dlg, wxID_ANY, type), 0, wxALIGN_CENTER_VERTICAL);
+
+            auto* color_panel = new wxPanel(&dlg, wxID_ANY, wxDefaultPosition, wxSize(FromDIP(52), FromDIP(18)));
+            wxColour colour(slot.color);
+            color_panel->SetBackgroundColour(colour.IsOk() ? colour : wxColour("#FFFFFF"));
+            grid->Add(color_panel, 0, wxALIGN_CENTER_VERTICAL);
+
+            grid->Add(new wxStaticText(&dlg, wxID_ANY, status), 0, wxALIGN_CENTER_VERTICAL);
+        }
+        main_sizer->Add(grid, 0, wxLEFT | wxRIGHT | wxBOTTOM, FromDIP(12));
+    }
+
+    auto* buttons = dlg.CreateSeparatedButtonSizer(wxOK);
+    if (buttons)
+        main_sizer->Add(buttons, 0, wxEXPAND | wxLEFT | wxRIGHT | wxBOTTOM, FromDIP(12));
+
+    dlg.SetSizerAndFit(main_sizer);
+    dlg.SetMinSize(wxSize(FromDIP(460), -1));
+    dlg.ShowModal();
+}
