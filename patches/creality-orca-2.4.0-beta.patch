+static int json_int_value(const json& obj, const char* key, int fallback = 0)
+{
+    auto it = obj.find(key);
+    if (it == obj.end())
+        return fallback;
+    if (it->is_number_integer())
+        return it->get<int>();
+    if (it->is_string()) {
+        int parsed = fallback;
+        return parse_int(it->get<std::string>(), parsed) ? parsed : fallback;
+    }
+    return fallback;
+}
